# Anthropic API key from console.anthropic.com  (REQUIRED)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model
ANTHROPIC_MODEL=claude-opus-4-8

# Database
DATABASE_URL=sqlite+aiosqlite:///data/mismathe.db

# Web server
HOST=0.0.0.0
PORT=8000

# Cookie-signing secret — change for production
SESSION_SECRET=change-me-to-a-long-random-string

# Timezone for daily nudges
TIMEZONE=Asia/Kolkata

# Default mentor mode for new students
DEFAULT_MODE=friend

# Push memory/ + conversation snapshots to GitHub
GITHUB_MEMORY_SYNC=true
GIT_BRANCH=
