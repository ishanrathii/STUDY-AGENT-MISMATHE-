# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model (default: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# Database path
DATABASE_URL=sqlite+aiosqlite:///data/mismathe.db

# Timezone (IANA name) — used for scheduling daily nudges, check-ins, streaks
TIMEZONE=Asia/Kolkata

# Default mentor mode for new students
DEFAULT_MODE=friend

# Optional: admin Telegram user id (receives error alerts)
ADMIN_USER_ID=
